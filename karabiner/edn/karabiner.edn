;; Karabiner-Elements 配置 · 由 Goku 编译为 karabiner.json
;;
;; 修饰键符号对照：
;;   C = left_command    Q = right_command
;;   T = left_control    W = right_control
;;   O = left_option     E = right_option
;;   S = left_shift      R = right_shift
;;
;;   !  前缀 → mandatory（必须按下）
;;   #  前缀 → optional（可有可无）
;;   ## 前缀 → optional any（忽略所有其他修饰键）
;;   !! → 全修饰键 (Cmd + Ctrl + Opt + Shift)

{
 ;; ──────────────────────────────────────────────────────────
 ;; 应用分组（在此集中维护，规则中直接引用名称）
 ;; ──────────────────────────────────────────────────────────
 :applications {:terminal ["^com\\.mitchellh\\.ghostty" "^dev\\.warp\\.Warp-Stable"]}

 ;; ──────────────────────────────────────────────────────────
 ;; 规则
 ;; ──────────────────────────────────────────────────────────
 :main [

  {:des "Caps Lock → Hyper (Ctrl + Option + Shift)"
   :rules [
    ;; ## 前缀：无论当前是否按住其他修饰键，caps_lock 都触发
    [:##caps_lock :!TOleft_shift]
   ]}

  {:des "Hyper + R/V/C/T/D/U/G/O/A → Ctrl + Key (Terminal)"
   :rules [
    [:!TOSr :!Tr :terminal]
    [:!TOSv :!Tv :terminal]
    [:!TOSc :!Tc :terminal]
    [:!TOSt :!Tt :terminal]
    [:!TOSd :!Td :terminal]
    [:!TOSu :!Tu :terminal]
    [:!TOSg :!Tg :terminal]
    [:!TOSo :!To :terminal]
    [:!TOSa :!Ta :terminal]
   ]}

  {:des "Hyper + H/J/K/L → Ctrl + Key (Terminal) / Arrow Keys (global)"
   :rules [
    ;; 终端中优先匹配 Ctrl 输出；顺序不可颠倒
    [:!TOSh :!Th :terminal]
    [:!TOSj :!Tj :terminal]
    [:!TOSk :!Tk :terminal]
    [:!TOSl :!Tl :terminal]
    ;; 其他所有应用：vi 方向键导航
    [:!TOSh :left_arrow]
    [:!TOSj :down_arrow]
    [:!TOSk :up_arrow]
    [:!TOSl :right_arrow]
   ]}

 ]
}
